--- a/drivers/pci/controller/Kconfig
+++ b/drivers/pci/controller/Kconfig
@@ -344,6 +344,15 @@ config PCIE_XILINX_CPM
 	  Say 'Y' here if you want kernel support for the
 	  Xilinx Versal CPM host bridge.
 
+config PCIE_REALTEK
+	bool "Realtek PCIe controller"
+	depends on MACH_REALTEK_RTL && RTL960X
+	depends on PCI
+	select PCI_HOST_COMMON
+	help
+	  Say Y here to enable PCIe controller support for the Realtek
+	  RTL9607C and similar SoCs.
+
 source "drivers/pci/controller/cadence/Kconfig"
 source "drivers/pci/controller/dwc/Kconfig"
 source "drivers/pci/controller/mobiveil/Kconfig"
--- a/drivers/pci/controller/Makefile
+++ b/drivers/pci/controller/Makefile
@@ -39,6 +39,7 @@ obj-$(CONFIG_PCI_LOONGSON) += pci-loongs
 obj-$(CONFIG_PCIE_HISI_ERR) += pcie-hisi-error.o
 obj-$(CONFIG_PCIE_APPLE) += pcie-apple.o
 obj-$(CONFIG_PCIE_MT7621) += pcie-mt7621.o
+obj-$(CONFIG_PCIE_REALTEK) += pcie-realtek.o
 
 # pcie-hisi.o quirks are needed even without CONFIG_PCIE_DW
 obj-y				+= dwc/
--- a/arch/mips/Kconfig
+++ b/arch/mips/Kconfig
@@ -1054,6 +1054,7 @@ config RTL960X
 	select SYS_SUPPORTS_SMP
 	select SYS_SUPPORTS_MIPS_CPS
 	select HAVE_PCI
+	select PCI_DRIVERS_GENERIC
 	select SYS_SUPPORTS_ZBOOT
 	select MIPS_EXTERNAL_TIMER
 
--- a/drivers/phy/realtek/Kconfig
+++ b/drivers/phy/realtek/Kconfig
@@ -3,7 +3,7 @@
 # Phy drivers for Realtek platforms
 #
 
-if ARCH_REALTEK || COMPILE_TEST
+if ARCH_REALTEK || RTL960X || COMPILE_TEST
 
 config PHY_RTK_RTD_USB2PHY
 	tristate "Realtek RTD USB2 PHY Transceiver Driver"
@@ -29,4 +29,13 @@ config PHY_RTK_RTD_USB3PHY
 	  DWC3 USB IP. This driver will do the PHY initialization
 	  of the parameters.
 
-endif # ARCH_REALTEK || COMPILE_TEST
+config PHY_RTK_PCIEPHY
+	tristate "Realtek PCIE PHY Transceiver Driver"
+	depends on OF
+	select GENERIC_PHY
+	help
+	  Say 'Y' here to add support for Realtek RTL9607 PCI PHY driver.
+	  This driver create the basic PHY instance and provides initialize
+	  callback for PCIe port.
+
+endif # ARCH_REALTEK || RTL960X || COMPILE_TEST
--- a/drivers/phy/realtek/Makefile
+++ b/drivers/phy/realtek/Makefile
@@ -1,3 +1,4 @@
 # SPDX-License-Identifier: GPL-2.0
 obj-$(CONFIG_PHY_RTK_RTD_USB2PHY)	+= phy-rtk-usb2.o
 obj-$(CONFIG_PHY_RTK_RTD_USB3PHY)	+= phy-rtk-usb3.o
+obj-$(CONFIG_PHY_RTK_PCIEPHY)		+= phy-rtk-pcie.o
